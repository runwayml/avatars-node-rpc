{
  "name": "@runwayml/avatars-node-rpc",
  "version": "0.0.1",
  "description": "Node.js handler for backend RPC tool calls in Runway avatar sessions",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "NOTICES"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/runwayml/avatars-node-rpc.git"
  },
  "keywords": [
    "runway",
    "avatars",
    "rpc",
    "realtime"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome lint src/",
    "lint:fix": "biome lint --write src/",
    "format": "biome format --write src/",
    "check": "biome check src/",
    "typecheck": "tsc --noEmit",
    "example:trivia": "tsx examples/trivia.ts",
    "example:multi-tool": "tsx examples/multi-tool.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@livekit/rtc-node": "^0.13.24"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "license": "MIT"
}
